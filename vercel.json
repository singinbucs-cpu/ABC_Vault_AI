{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/scan",
      "dest": "/api/scan.js"
    },
    {
      "src": "/api/auth-config",
      "dest": "/api/auth-config.js"
    },
    {
      "src": "/api/me",
      "dest": "/api/me.js"
    },
    {
      "src": "/api/cron-scan",
      "dest": "/api/cron-scan.js"
    },
    {
      "src": "/api/hot-items",
      "dest": "/api/hot-items.js"
    },
    {
      "src": "/api/pushover-test",
      "dest": "/api/pushover-test.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-scan",
      "schedule": "* * * * *"
    }
  ]
}
